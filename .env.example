# Shared
NODE_ENV=development

# Database
POSTGRES_DB=aitourguide
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/aitourguide?schema=public

# API
API_PORT=3001
JWT_SECRET=change-me
ELEVENLABS_API_KEY=change-me

# AWS SES (for OTP emails)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
SES_FROM_EMAIL=noreply@yourdomain.com

# Landing
LANDING_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Mobile
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_ELEVENLABS_AGENT_ID=change-me

# Proxy
CADDY_EMAIL=you@example.com

# Amadeus
AMADEUS_CLIENT_ID=change-me
AMADEUS_CLIENT_SECRET=change-me
AMADEUS_BASE_URL=https://test.api.amadeus.com

# Tripadvisor
TRIPADVISOR_API_KEY=change-me

# Web Search (Brave Search API — free tier: https://brave.com/search/api/)
BRAVE_SEARCH_API_KEY=change-me

# OpenAI (embeddings for memory)
OPENAI_API_KEY=change-me
